<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/medibook_background">

    <!-- Top header bar matching web teal panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/medibook_primary_dark"
        android:paddingHorizontal="16dp">

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/btn_accent"
            android:layout_marginEnd="10dp" />

        <TextView
            android:id="@+id/tvHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="MediBook"
            android:textColor="@color/medibook_surface"
            android:textSize="18sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground" />

        <Button
            android:id="@+id/btnMyAppointments"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="My Appointments"
            android:textSize="12sp"
            android:textColor="@color/medibook_surface"
            android:background="@null"
            android:paddingHorizontal="8dp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Logout"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/medibook_accent"
            android:background="@drawable/btn_outline_accent"
            android:paddingHorizontal="14dp" />
    </LinearLayout>

    <!-- Filter card with dropdown -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:strokeColor="@color/medibook_border"
        app:strokeWidth="1dp"
        app:contentPadding="12dp"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:hint="Specialization"
            app:endIconMode="dropdown_menu"
            app:boxStrokeColor="@color/medibook_primary"
            app:boxStrokeWidth="1dp"
            app:hintTextColor="@color/medibook_primary">

            <AutoCompleteTextView
                android:id="@+id/actSpecialization"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:textSize="14sp"
                android:textColor="@color/medibook_ink"
                android:inputType="none"
                android:paddingHorizontal="8dp" />
        </com.google.android.material.textfield.TextInputLayout>
    </com.google.android.material.card.MaterialCardView>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_gravity="center"
        android:layout_marginTop="32dp"
        android:indeterminateTint="@color/medibook_primary" />

    <TextView
        android:id="@+id/tvError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/medibook_error"
        android:visibility="gone"
        android:paddingHorizontal="16dp"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No doctors found."
        android:textColor="@color/medibook_ink_soft"
        android:visibility="gone"
        android:gravity="center"
        android:layout_marginTop="32dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDoctors"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp"
        android:clipToPadding="false" />

</LinearLayout>
