<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/medibook_background">

    <!-- Top header bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/medibook_primary_dark"
        android:paddingHorizontal="16dp">

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/btn_accent"
            android:layout_marginEnd="10dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="MediBook"
            android:textColor="@color/medibook_surface"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Logout"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/medibook_accent"
            android:background="@drawable/btn_outline_accent"
            android:paddingHorizontal="14dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Welcome section -->
            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome back."
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/medibook_ink" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manage your health appointments from one place."
                android:textSize="14sp"
                android:textColor="@color/medibook_ink_soft"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="20dp" />

            <!-- Appointment stats card -->
            <LinearLayout
                android:id="@+id/cardAppointments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/card_background"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="YOUR APPOINTMENTS"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        android:textColor="@color/medibook_ink_soft" />

                    <TextView
                        android:id="@+id/tvAppointmentCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="\u2014"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/medibook_ink"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="upcoming"
                        android:textSize="13sp"
                        android:textColor="@color/medibook_ink_soft"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_calendar_month"
                    android:contentDescription="Appointments"
                    android:tint="@color/medibook_primary" />
            </LinearLayout>

            <!-- Quick actions header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="QUICK ACTIONS"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:textColor="@color/medibook_ink_soft"
                android:layout_marginBottom="12dp" />

            <!-- Browse Doctors card -->
            <LinearLayout
                android:id="@+id/cardBrowseDoctors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/card_item_background"
                android:padding="16dp"
                android:layout_marginBottom="10dp"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_local_hospital"
                    android:contentDescription="Doctors"
                    android:tint="@color/medibook_accent" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Browse Doctors"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/medibook_ink" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Find a doctor and book an appointment"
                        android:textSize="13sp"
                        android:textColor="@color/medibook_ink_soft"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- My Appointments card -->
            <LinearLayout
                android:id="@+id/cardMyAppointments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/card_item_background"
                android:padding="16dp"
                android:layout_marginBottom="10dp"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_calendar_month"
                    android:contentDescription="Appointments"
                    android:tint="@color/medibook_primary" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="My Appointments"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/medibook_ink" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View all your booked appointments"
                        android:textSize="13sp"
                        android:textColor="@color/medibook_ink_soft"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- My Profile card -->
            <LinearLayout
                android:id="@+id/cardMyProfile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/card_item_background"
                android:padding="16dp"
                android:layout_marginBottom="10dp"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_local_hospital"
                    android:contentDescription="Profile"
                    android:tint="@color/medibook_accent" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="My Profile"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/medibook_ink" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View and edit your personal information"
                        android:textSize="13sp"
                        android:textColor="@color/medibook_ink_soft"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
