<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/medibook_surface"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Appointment Details"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/medibook_ink" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/medibook_border"
            android:layout_marginVertical="12dp" />

        <!-- Appointment info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Doctor"
                android:textSize="13sp"
                android:textColor="@color/medibook_ink_soft" />

            <TextView
                android:id="@+id/tvDetailDoctor"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/medibook_ink" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Scheduled"
                android:textSize="13sp"
                android:textColor="@color/medibook_ink_soft" />

            <TextView
                android:id="@+id/tvDetailTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/medibook_ink" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Status"
                android:textSize="13sp"
                android:textColor="@color/medibook_ink_soft" />

            <TextView
                android:id="@+id/tvDetailStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp" />
        </LinearLayout>

        <!-- Health record section -->
        <ProgressBar
            android:id="@+id/progressRecord"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginVertical="12dp"
            android:indeterminateTint="@color/medibook_primary"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvNoRecord"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No health record for this appointment."
            android:textSize="13sp"
            android:textColor="@color/medibook_ink_soft"
            android:visibility="gone"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/layoutRecord"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/medibook_background"
            android:padding="14dp"
            android:visibility="gone"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HEALTH RECORD"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:textColor="@color/medibook_primary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Diagnosis"
                android:textSize="11sp"
                android:textColor="@color/medibook_ink_soft" />

            <TextView
                android:id="@+id/tvDetailDiagnosis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/medibook_ink"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Notes"
                android:textSize="11sp"
                android:textColor="@color/medibook_ink_soft" />

            <TextView
                android:id="@+id/tvDetailNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/medibook_ink"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvDetailRecordedAt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/medibook_ink_soft" />
        </LinearLayout>

        <!-- FDA suggestions section -->
        <LinearLayout
            android:id="@+id/layoutFda"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OPENFDA DRUG SUGGESTIONS"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:textColor="@color/medibook_primary"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/layoutFdaItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/medibook_border"
            android:layout_marginVertical="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <TextView
                android:id="@+id/tvCancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cancel Appointment"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#DC2626"
                android:paddingHorizontal="8dp"
                android:paddingVertical="6dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvDetailClose"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Close"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/medibook_primary"
                android:paddingHorizontal="8dp"
                android:paddingVertical="6dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
