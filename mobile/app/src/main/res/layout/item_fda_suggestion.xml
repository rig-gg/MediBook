<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/medibook_surface"
    android:padding="12dp"
    android:layout_marginBottom="6dp">

    <TextView
        android:id="@+id/tvDrugName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="@color/medibook_ink" />

    <TextView
        android:id="@+id/tvDrugGeneric"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="@color/medibook_ink_soft"
        android:layout_marginTop="2dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvDrugRoute"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="@color/medibook_ink_soft"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvDrugIndication"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="@color/medibook_ink_soft"
        android:layout_marginTop="4dp"
        android:visibility="gone" />

</LinearLayout>
