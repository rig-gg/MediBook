# ==========================================
# Database Configuration (Supabase)
# ==========================================

# Database credentials — replace with your Supabase project values
DB_URL=jdbc:postgresql://your-project-ref.pooler.supabase.com:5432/postgres
DB_USERNAME=your_database_username
DB_PASSWORD=your_database_password

# JWT Secret — MUST be at least 43 characters (256 bits base64-encoded)
# Generate one with: openssl rand -base64 64
JWT_SECRET=your_random_jwt_secret_here_at_least_43_chars

SERVER_PORT=8080

# FR-011: Mailtrap SMTP
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=your_mailtrap_username
MAIL_PASSWORD=your_mailtrap_password

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173

# DataSeeder — leave blank to use default "ChangeMe@1234"
SEED_ADMIN_PASSWORD=
SEED_DOCTOR_PASSWORD=
SEED_STAFF_PASSWORD=
