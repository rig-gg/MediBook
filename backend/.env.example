# ==========================================
# Database Configuration (Supabase)
# ==========================================

Environment variables for database connection and JWT secret. Replace the placeholder values with your actual database credentials and a secure JWT secret.
DB_URL=jdbc:postgresql://your-project-ref.pooler.supabase.com:5432/postgres;
DB_USERNAME=your_database_username;
DB_PASSWORD=your_database_password;
JWT_SECRET=your_random_jwt_secret;

SERVER_PORT=8080